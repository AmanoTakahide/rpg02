# おすすめ設計

## ① gameState を増やす

```js
const GAME_STATE = {
    MAP: "MAP",
    MESSAGE: "MESSAGE",
    CHOICE: "CHOICE",

    MENU: "MENU",
    MENU_PARTY: "MENU_PARTY",
    MENU_BAG: "MENU_BAG",
    MENU_STATUS: "MENU_STATUS"
};
```

で：

```js
let gameState = GAME_STATE.MAP;
```

にする。

これ超大事。

---

# ② スタートメニュー専用変数

```js
const START_MENU_ITEMS = [
    "てもち",
    "バッグ",
    "タカヒデ",
    "レポート",
    "とじる"
];

let menuIndex = 0;
```

---

# ③ STARTボタンでメニュー開く

handleInput に追加。

```js
if (command === "START") {
    if (gameState === GAME_STATE.MAP) {
        gameState = GAME_STATE.MENU;
        menuIndex = 0;
    }
    return;
}
```

---

# ④ MENU操作

```js
if (gameState === GAME_STATE.MENU) {

    if (command === "UP") {
        menuIndex =
            (menuIndex - 1 + START_MENU_ITEMS.length)
            % START_MENU_ITEMS.length;
    }

    else if (command === "DOWN") {
        menuIndex =
            (menuIndex + 1)
            % START_MENU_ITEMS.length;
    }

    else if (command === "B") {
        gameState = GAME_STATE.MAP;
    }

    else if (command === "A") {

        const selected =
            START_MENU_ITEMS[menuIndex];

        if (selected === "てもち") {
            gameState = GAME_STATE.MENU_PARTY;
        }

        else if (selected === "バッグ") {
            gameState = GAME_STATE.MENU_BAG;
        }

        else if (selected === "タカヒデ") {
            gameState = GAME_STATE.MENU_STATUS;
        }

        else if (selected === "とじる") {
            gameState = GAME_STATE.MAP;
        }
    }

    return;
}
```

