# ⑥ drawStartMenu()

これが本体。

```js
function drawStartMenu() {

    ctx.fillStyle = "white";
    ctx.fillRect(350, 20, 120, 180);

    ctx.strokeStyle = "black";
    ctx.strokeRect(350, 20, 120, 180);

    ctx.fillStyle = "black";
    ctx.font = "16px sans-serif";

    START_MENU_ITEMS.forEach((item, index) => {

        const y = 50 + index * 30;

        if (index === menuIndex) {
            ctx.fillText("▶", 360, y);
        }

        ctx.fillText(item, 390, y);
    });
}
```

